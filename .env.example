# ── Gemini AI (required) ──────────────────────────────────────────────────────
# Get free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Supabase (required for multi-user auth + production DB) ───────────────────
# Supabase dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase dashboard → Project Settings → API → JWT Secret → click Reveal
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Supabase dashboard → Project Settings → Database → Connection String → URI
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.your-project-ref.supabase.co:5432/postgres

# ── Cloudinary (optional — local file storage used if blank) ─────────────────
# Dashboard → Account Details → API Environment variable (full string)
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ── CORS (optional — defaults to * which allows all origins) ─────────────────
CORS_ORIGINS=*
