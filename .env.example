# Gemini API Key (required) — get free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL connection string (optional — leave blank to use local SQLite)
# Format: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Cloudinary URL (optional — leave blank to store uploads locally)
# Format: cloudinary://api_key:api_secret@cloud_name
CLOUDINARY_URL=

# CORS allowed origins (optional — comma-separated list, defaults to *)
# Example for production: https://your-app.vercel.app
CORS_ORIGINS=*
